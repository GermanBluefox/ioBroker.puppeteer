  "items": {
      "useExternalBrowser": {
          "type": "checkbox",
          "label": "useExternalBrowser"
      },
      "executablePath": {
          "placeholder": "/usr/bin/chromium-browser",
          "hidden": "!data.useExternalBrowser",
          "newLine": true,
          "type": "text",
          "label": "executablePath"
      },
      "additionalArgs": {
          "newLine": true,
          "label": "additionalLaunchArgs",
          "type": "table",
          "uniqueColumns": ["Argument"],
          "xs": 12,
          "items": [
              {
                  "attr": "Argument",
                  "label": "Argument",
                  "filter": false,
                  "sort": false,
                  "type": "autocomplete",
                  "freeSolo": true,
                  "options": ["--disable-lcd-text", "--disable-composited-antialiasing"]
              }
          ]
      },
      "allowWebAccess": {
          "type": "checkbox",
          "label": "allowWebRequests",
          "help": "allowWebRequestsHelp"
      },
      "bind": {
          "hidden": "!data.allowWebAccess",
          "newLine": true,
          "type": "ip",
          "listenOnAllPorts": true,
          "label": "bindAddress",
          "xs": 12,
          "sm": 12,
          "md": 8,
          "lg": 5
      },
      "port": {
          "hidden": "!data.allowWebAccess",
          "type": "number",
          "min": 1,
          "max": 65565,
          "label": "port",
          "xs": 12,
          "sm": 12,
          "md": 4,
          "lg": 3
      },
      "secure": {
          "hidden": "!data.allowWebAccess",
          "newLine": true,
          "type": "checkbox",
          "label": "secure",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 2
      },
      "certPublic": {
          "type": "certificate",
          "hidden": "!data.secure || !data.allowWebAccess",
          "certType": "public",
          "validator": "!data.secure || data.certPublic",
          "label": "certPublic",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 2
      },
      "certPrivate": {
          "hidden": "!data.secure || !data.allowWebAccess",
          "type": "certificate",
          "certType": "private",
          "validator": "!data.secure || data.certPrivate",
          "label": "certPrivate",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 2
      },
      "certChained": {
          "hidden": "!data.secure || !data.allowWebAccess",
          "type": "certificate",
          "certType": "chained",
          "label": "certChained",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 2
      },
      "auth": {
          "newLine": true,
          "hidden": "!data.allowWebAccess",
          "type": "checkbox",
          "confirm": {
              "condition": "!data.secure && data.auth",
              "title": "warningTitle",
              "text": "unsecureAuth",
              "ok": "ignoreWarning",
              "cancel": "disableAuth",
              "type": "warning",
              "alsoDependsOn": ["secure"]
          },
          "label": "auth",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 2
      }
  }
}